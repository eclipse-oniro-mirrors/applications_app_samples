const layoutSerialName = 'entry/ets/turbotrans_JSON/layout.ets/Layout.class';

export class LayoutSerializer extends Serializer<Layout> {
  private static _INSTANCE?: LayoutSerializer;
  public readonly serialName: string = layoutSerialName;

  static get INSTANCE(): LayoutSerializer {
    if (!LayoutSerializer._INSTANCE) {
      LayoutSerializer._INSTANCE = new LayoutSerializer();
    }
    return LayoutSerializer._INSTANCE;
  }

  private readonly typeSerializer: StringSerializer = StringSerializer.INSTANCE;
  private getArrSerializer: () => ArraySerializer<number> = () => {
    const serializer: ArraySerializer<number> = new ArraySerializer<number>(NumberSerializer.INSTANCE);
    this.getArrSerializer = () => serializer;
    return serializer;
  };

  private getSerialDescriptor: () => SerialDescriptor = () => {
    const descriptor: SerialDescriptor = buildClassSerialDescriptor(
      layoutSerialName,
      builder => {
        builder.element({
          elementName: 'type',
          descriptor: this.typeSerializer.serialDescriptor
        });
        builder.element({
          elementName: 'arr',
          descriptor: lazy(() => this.getArrSerializer().serialDescriptor)
        });
      }
    )
    this.getSerialDescriptor = () => descriptor;
    return descriptor;
  }

  get serialDescriptor(): SerialDescriptor {
    return this.getSerialDescriptor();
  }

  private constructor() {
    super();
  }

  serialize(encoder: Encoder, value: Layout) {
    return this.innerSerialize(encoder, value);
  }

  private innerSerialize(encoder: Encoder, value: Layout) {
    const keys = this.serialDescriptor.elementNames;
    const result = encoder.newObject();
    encoder.encodeStringElement(result, keys[0], value.type);
    encoder.encodeSerializableElement(result, keys[1], this.getArrSerializer(), value.arr);

    return result;
  }

  deserialize(decoder: Decoder, plain: ESObject): Layout {
    const keys = this.serialDescriptor.elementDecodingNames;

    const result = new Layout(
    );


    const typePlainValue = plain[keys[0]];
    result.type = typePlainValue === undefined ? '' :
      decoder.decodeString(plain[keys[0]]);
    const arrPlainValue = plain[keys[1]];
    result.arr = arrPlainValue === undefined ? [] :
      this.getArrSerializer().deserialize(decoder, plain[keys[1]]);

    return result as Layout;
  }
}

