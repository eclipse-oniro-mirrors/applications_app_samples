{
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "material": {
          "certpath": "xxxxxxx",
          "keyAlias": "debugKey",
          "keyPassword": "xxxxx",
          "profile": "xxxxxxxx",
          "signAlg": "SHA256withECDSA",
          "storeFile": "xxxxxxx",
          "storePassword": "0000001B5E74CE99E59428C5669CC1ECD6A427D87EC2B07CDF5CE1C6AFFE64F8A3B1F987C220041F26B1BF"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compileSdkVersion": 26,
        "compatibleSdkVersion": 26,
        "arkTSVersion": "1.2",
        "runtimeOS": "OpenHarmony",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        },
        "targetSdkVersion": 26,
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}