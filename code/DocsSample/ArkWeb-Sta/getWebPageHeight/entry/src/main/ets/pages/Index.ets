import {  Entry, Component, Column, Button } from '@kit.ArkUI';

@Entry
@Component
struct Index {
  build() {
    Column() {
      Button('getPageHeight')
        .onClick(() => {
          this.getUIContext().getRouter().pushUrl({ url: 'pages/getPageHeight' });
        })
      Button('JSBridgePageHeight')
        .onClick(() => {
          this.getUIContext().getRouter().pushUrl({ url: 'pages/JSBridgePageHeight' });
        })
      Button('setTimeoutPageHeight')
        .onClick(() => {
          this.getUIContext().getRouter().pushUrl({ url: 'pages/setTimeoutPageHeight' });
        })
    }.height('100%')
    .width('100%')
  }
}