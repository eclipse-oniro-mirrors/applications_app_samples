// [Start static_isolation_process_config]
{
  "module": {
// [StartExclude static_isolation_process_config]
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "default",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
// [EndExclude static_isolation_process_config]
    "abilities": [
// [StartExclude static_isolation_process_config]
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      },
// [EndExclude static_isolation_process_config]
      {
        "name": "EntryAbility1",
        "srcEntry": "./ets/entryability1/EntryAbility1.ets",
// [StartExclude static_isolation_process_config]
        "description": "$string:EntryAbility1_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility1_label",
        "exported": true,
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
// [EndExclude static_isolation_process_config]
        "process": ":processTag"
      },
      {
        "name": "EntryAbility2",
        "srcEntry": "./ets/entryability2/EntryAbility2.ets",
// [StartExclude static_isolation_process_config]
        "description": "$string:EntryAbility2_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility2_label",
        "exported": true,
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
// [EndExclude static_isolation_process_config]
        "process": ":processTag"
      }
    ],
// [StartExclude static_isolation_process_config]
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
// [EndExclude static_isolation_process_config]
  }
}
// [End static_isolation_process_config]