{
  "module": {
    "name": "SetBackgroundColor",
    "type": "feature",
    "description": "$string:module_desc",
    "mainElement": "SetBackgroundColorAbility",
    "deviceTypes": [
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "SetBackgroundColorAbility",
        "srcEntry": "./ets/setbackgroundcolorability/SetBackgroundColorAbility.ets",
        "description": "$string:SetBackgroundColorAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:SetBackgroundColorAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true
      }
    ]
  }
}