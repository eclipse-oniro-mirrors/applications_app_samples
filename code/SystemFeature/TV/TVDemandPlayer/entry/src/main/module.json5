{
  "module": {
    "name": "entry",
    "type": "entry",
    "srcEntry": "./ets/Application/MyAbilityStage.ets",
    "description": "$string:entry_desc",
    "mainElement": "MainAbility",
    "deviceTypes": [
      "default",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "MainAbility",
        "srcEntry": "./ets/MainAbility/MainAbility.ets",
        "description": "$string:MainAbility_desc",
        "icon": "$media:demand_player_4x",
        "label": "$string:MainAbility_label",
        "startWindowIcon": "$media:icon_demand_onFocus",
        "startWindowBackground": "$color:white",
        "orientation": "follow_desktop",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home",
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "file",
                "type": "video/*",
                "linkFeature": "FileOpen"
              }
            ]
          }
        ]
      },
      {
        "name": "DlnaAbility",
        "srcEntry": "./ets/dlnaAbility/DlnaAbility.ets",
        "description": "$string:Dlnaability_desc",
        "icon": "$media:layered_image",
        "label": "$string:Dlnaability_label",
        "startWindowIcon": "$media:dlnaicon",
        "startWindowBackground": "$color:start_window_background"
      },
    ],
    "extensionAbilities": [
      {
        "name": "ServiceAbility",
        "srcEntrance": "./ets/serviceability/ServiceAbility.ets",
        "label": "$string:app_name",
        "description": "$string:app_name",
        "type": "service"
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.VIBRATE"
      },
      {
        "name": "ohos.permission.WRITE_AUDIO",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": [
            "MainAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_MEDIA",
        "reason": '$string:app_name',
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.WRITE_MEDIA",
        "reason": "$string:app_name",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.MEDIA_LOCATION",
        "reason": "$string:app_name",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.READ_IMAGEVIDEO",
        "reason": "$string:app_name",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.READ_AUDIO",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": [
            "MainAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_DOCUMENT",
        "reason": "$string:app_name",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.DISTRIBUTED_DATASYNC",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": [
            "MainAbility"
          ],
          "when": "always"
        },
      },
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.REQUIRE_FORM"
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO"
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO_PRIVILEGED"
      },
      {
        "name": "ohos.permission.DISTRIBUTED_SOFTBUS_CENTER"
      },
      {
        "name": "ohos.permission.FILE_ACCESS_MANAGER"
      },
      {
        "name": "ohos.permission.STORAGE_MANAGER"
      },
      {
        "name": "ohos.permission.CAPTURE_SCREEN"
      },
      {
        "name": "ohos.permission.ACCESS_NOTIFICATION_POLICY"
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:app_name",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.MODIFY_AUDIO_SETTINGS"
      },
      {
        "name": "ohos.permission.MANAGE_AUDIO_CONFIG"
      },
      {
        "name": "ohos.permission.ACCESS_SERVICE_DM"
      },
      {
        "name": "ohos.permission.START_ABILITIES_FROM_BACKGROUND"
      },
      {
        "name": "ohos.permission.START_INVISIBLE_ABILITY"
      },
      {
        "name": "ohos.permission.MANAGE_MISSIONS"
      },
      {
        "name": "ohos.permission.GET_RUNNING_INFO"
      },
      {
        "name": 'ohos.permission.INJECT_INPUT_EVENT'
      }
    ]
  }
}