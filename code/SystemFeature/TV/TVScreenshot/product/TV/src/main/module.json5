{
  "module": {
    "name": "TV",
    "type": "entry",
    "srcEntry": "./ets/application/AbilityStage.ets",
    "description": "$string:mainability_description",
    "mainElement": "com.ohos.screenshot.ServiceExtAbility",
    "deviceTypes": [
      "default",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "extensionAbilities": [
      {
        "exported": true,
        "skills": [
          {
            "actions": [
              "com.ohos.systemui.action.TOGGLE"
            ]
          }
        ],
        "permissions": [
          "ohos.permission.CAPTURE_SCREEN"
        ],
        "srcEntry": "./ets/serviceExtAbility/ServiceExtAbility.ets",
        "name": "com.ohos.screenshot.ServiceExtAbility",
        "icon": "$media:icon",
        "description": "$string:mainability_description",
        "label": "$string:app_name",
        "type": "service",
        "metadata": [
          {
            "name": "com.ohos.systemui.action.TOGGLE",
            "value": "\"pluginType\":\"1\",\"clickAction\":\"ability=com.ohos.screenshot|com.ohos.screenshot.ServiceExtAbility\"",
            "resource": "$profile:main_pages"
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.MEDIA_LOCATION",
        "usedScene": {
          "when": "inuse"
        },
        "reason": "$string:media_location_reason"
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO_PRIVILEGED"
      },
      {
        "name": "ohos.permission.CAPTURE_SCREEN"
      },
      {
        "name": "ohos.permission.START_ABILITIES_FROM_BACKGROUND"
      },
      {
        "name": "ohos.permission.WRITE_IMAGEVIDEO",
        "usedScene": {
          "when": "inuse"
        },
        "reason": "$string:write_media_reason"
      },
      {
        "name": "ohos.permission.SYSTEM_FLOAT_WINDOW"
      },
      {
        "name": "ohos.permission.CUSTOM_SCREEN_CAPTURE",
        "reason": "$string:screenshot_reason",
        "usedScene": {
          "when": "inuse"
        }
      }
    ]
  }
}
