{
  "module": {
    "name": "tv_pairservice",
    "type": "feature",
    "srcEntry": "./ets/Application/AbilityStage.ets",
    "description": "$string:module_pair_desc",
    "mainElement": "com.ohos.systemui.pairservice.ServiceExtAbility",
    "deviceTypes": [
      "default"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "metadata": [
      {
        "name": "ArkTSPartialUpdate",
        "value": "true"
      }
    ],
    "pages": "$profile:main_pages",
    "extensionAbilities": [
      {
        "exported": true,
        "srcEntry": "./ets/service/PartsPairService.ets",
        "name": "com.ohos.systemui.pairservice.ServiceExtAbility",
        "icon": "$media:app_icon",
        "description": "$string:module_pair_desc",
        "label": "$string:app_name",
        "type": "service"
      }
    ],

    "requestPermissions": [
      {
        "name": "ohos.permission.USE_BLUETOOTH",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      },
      {
        "name": "ohos.permission.DISCOVER_BLUETOOTH",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      },
      {
        "name": "ohos.permission.ACCESS_BLUETOOTH",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      },
      {
        "name": "ohos.permission.MANAGE_BLUETOOTH",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      },
      {
        "name": "ohos.permission.START_ABILITIES_FROM_BACKGROUND",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      },
      {
        "name": "ohos.permission.START_INVISIBLE_ABILITY",
        "reason": "$string:app_name",
        "usedScene": {
          "abilities": ['PartsPairService'],
          "when": 'always'
        }
      }
    ]
  }
}